---
import LayoutHome from "../layouts/LayoutHome.astro"
import Time from "../components/icon/Time.astro"
import ChevronRight from "../components/icon/ChevronRight.astro"
---

<LayoutHome title="Kuis | Platform Interaktif Gratis - HiraganaEasy">
  <div data-swap="quiz" class="min-h-screen flex items-center justify-center p-4 sm:p-6 md:p-8 lg:p-12">
    
    <div class="w-full max-w-full sm:max-w-md md:max-w-2xl lg:max-w-4xl border border-gray-50 bg-white flex flex-col md:flex-row rounded-2xl">
      
      <div class="bg-gradient-to-br from-red-600 to-red-700 rounded-t-2xl md:rounded-l-2xl md:rounded-tr-none p-10 md:w-5/12 flex flex-col justify-center items-center text-center">
        
        <div class="relative">
          <span class="inline-block px-4 py-1 rounded-full text-white text-xs font-bold mb-4 bg-red-200/50">
            CHALLENGE
          </span>
          <h1 class="text-4xl lg:text-5xl font-black text-white mb-2 tracking-tighter">
            Hiragana<span class="text-red-200">Easy</span>
          </h1>
          <p class="text-red-100 font-medium text-lg italic opacity-90">Kuis Interaktif</p>
          <div class="h-1.5 w-10 bg-red-300 mt-6 mx-auto rounded-full"></div>
        </div>
      </div>

      <div class="p-8 md:p-12 md:w-7/12 flex flex-col justify-center">
        <div class="mb-8">
          <h2 class="text-2xl font-bold text-gray-800">Siap untuk tes?</h2>
          <p class="text-gray-500 text-sm mt-1">Pilih intensitas latihan Anda sebelum memulai.</p>
        </div>

        <form data-ajax action="/partials/kuis" method="post" class="space-y-8">
          <div>
            <label for="soal" class="text-gray-400 text-xs font-bold mb-3 flex items-center gap-2 uppercase">
              <Time class="w-4 h-4" /> Jumlah Pertanyaan
            </label>
            
            <div class="relative">
              <select class="w-full p-4 bg-white rounded-2xl border-2 border-gray-100 focus:ring-4 focus:ring-red-500 text-gray-700 font-semibold" 
                id="soal" 
                name="soal"
              >
                <option value="10">10 Pertanyaan</option>
                <option value="20">20 Pertanyaan</option>
                <option value="30">30 Pertanyaan</option>
              </select>
            </div>
          </div>

          <button type="submit" class="group w-full bg-red-600 text-white font-bold py-5 px-8 rounded-2xl flex items-center justify-center gap-3">
              <span class="tracking-wide">MULAI SEKARANG</span>
              <div class="transition-transform group-hover:translate-x-1">
                <ChevronRight />
              </div>
          </button>
        </form>
        <p class="mt-8 text-center text-xs text-gray-400">
          Uji kemampuan Hiragana Anda secara sistematis.
        </p>
      </div>
    </div>
  </div>
</LayoutHome>
