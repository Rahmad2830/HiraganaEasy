---
import '../styles/global.css'
import HeadersHome from "../components/HeadersHome.astro"
import Footer from "../components/Footer.astro"
const { title } = Astro.props
---
<!doctype html>
<html lang="id">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/favicon.ico" />
		
    <meta property="og:title" content="Belajar Hiragana Dengan Mudah | HiraganaEasy - Platform Interaktif Gratis" />
    <meta property="og:description" content="Belajar hiragana Jepang jadi mudah dan menyenangkan! Platform interaktif dengan kuis, latihan kosakata, gamifikasi, simpan progress, mulai dari nol tanpa romaji. Cocok untuk pemula yang ingin cepat membaca dan mengingat huruf hiragana." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://hiraganaeasy.vercel.app/" />
    <meta property="og:image" content="https://hiraganaeasy.vercel.app/img/HEasy.png" />
    <meta property="og:image:alt" content="Ilustrasi huruf hiragana Jepang interaktif untuk belajar mudah" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="HiraganaEasy" />
    <meta property="og:locale" content="id_ID" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Belajar Hiragana Dengan Mudah | HiraganaEasy" />
    <meta name="twitter:description" content="Platform belajar hiragana interaktif gratis. Kuis seru, latihan kosakata, simpan progress. Mulai belajar sekarang tanpa biaya!" />
    <meta name="twitter:image" content="https://hiraganaeasy.vercel.app/img/HEasy.png" />
    <meta name="twitter:image:alt" content="Huruf hiragana Jepang dengan desain menarik untuk pemula" />
    <meta name="description" content="Belajar hiragana Jepang praktis dan cepat hafal dengan kuis interaktif, latihan kosakata sehari-hari, gamifikasi, serta simpan progress. Gratis selamanya!" />
		
		<script type="module" src="https://cdn.jsdelivr.net/gh/Rahmad2830/Briz@v1.0.3/dist/Briz.min.js"></script>
		<script src="/script/script.js" type="module"></script>
		<meta name="generator" content={Astro.generator} />
		<title>{ title }</title>
	</head>
	<body class="bg-slate-200 flex flex-col min-h-screen">
	  <header>
	    <HeadersHome />
	  </header>
	  <main class="flex-grow">
		  <slot />
	  </main>
	  <Footer />
	</body>
</html>
