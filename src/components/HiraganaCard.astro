---
const { arr } = Astro.props
---

<div class="grid grid-cols-10 gap-5 border-t border-slate-300 p-6 relative">
  { arr.map(vw => (
  <button class="absolute -top-4 left-1/2 -translate-x-1/2 py-1 px-4 rounded-full bg-red-100 text-red-500 font-semibold text-sm">{ vw.group }-group</button>
  <div class="col-span-5 md:col-span-2">
    <div class="bg-gray-200 rounded-xl p-4 text-center">
      <h1 class="text-5xl font-extrabold">{ vw.char }</h1>
      <p class="text-center text-lg mt-3">{ vw.romaji.toUpperCase() }</p>
      <i class="text-center text-gray-500 text-lg mt-3">{ vw.category }</i>
    </div>
  </div>
  ))}
</div>